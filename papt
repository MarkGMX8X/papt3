# Papt3 - универсальная обёртка для pacman + yay с синтаксисом как у apt


import sys
import subprocess
import shutil

REAL_PACMAN = "/usr/bin/pacman"
YAY_CMD = "yay"

def is_yay_installed():
    return shutil.which(YAY_CMD) is not None

def is_in_repos(pkg):
    result = subprocess.run(['pacman', '-Ss', f'^{pkg}$'], capture_output=True, text=True)
    return result.returncode == 0 and pkg in result.stdout

def run_cmd(cmd, use_sudo=False):
    if use_sudo and cmd[0] != "sudo":
        cmd = ["sudo"] + cmd
    try:
        subprocess.run(cmd, check=True)
    except subprocess.CalledProcessError as e:
        sys.exit(e.returncode)

def main():
    if len(sys.argv) < 2:
        print("Использование: papt {update|upgrade|install|remove|search|autoremove}")
        sys.exit(1)

    cmd = sys.argv[1]
    args = sys.argv[2:]

    if cmd == "update":
        run_cmd([REAL_PACMAN, "-Sy"], use_sudo=True)
        if is_yay_installed():
            run_cmd([YAY_CMD, "-Sy"], use_sudo=False)
    elif cmd == "upgrade":
        if not is_yay_installed():
            run_cmd([REAL_PACMAN, "-Syu"], use_sudo=True)
        else:
            run_cmd([YAY_CMD, "-Syu"], use_sudo=False)
    elif cmd == "install":
        for pkg in args:
            if is_in_repos(pkg):
                run_cmd([REAL_PACMAN, "-S", pkg], use_sudo=True)
            elif is_yay_installed():
                run_cmd([YAY_CMD, "-S", pkg], use_sudo=False)
            else:
                print(f"Не найден: {pkg} (и yay не установлен)")
    elif cmd == "remove":
        run_cmd([REAL_PACMAN, "-Rns"] + args, use_sudo=True)
    elif cmd == "search":
        run_cmd([REAL_PACMAN, "-Ss"] + args, use_sudo=True)
        if is_yay_installed():
            print("\n--- AUR ---")
            run_cmd([YAY_CMD, "-Ss"] + args, use_sudo=False)
    elif cmd == "autoremove":
        run_cmd([REAL_PACMAN, "-Rns", "$(pacman -Qdtq)"], use_sudo=True)
    else:
        print(f"Неизвестная команда: {cmd}")

if __name__ == "__main__":
    main()